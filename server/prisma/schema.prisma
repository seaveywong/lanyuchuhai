generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int        @id @default(autoincrement())
  parentId  Int?       @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  name      String
  slug      String     @unique
  sortOrder Int        @default(0) @map("sort_order")
  status    String     @default("active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  products  Product[]

  @@index([parentId, sortOrder])
  @@map("categories")
}

model Product {
  id           Int         @id @default(autoincrement())
  categoryId   Int         @map("category_id")
  category     Category    @relation(fields: [categoryId], references: [id])
  name         String
  description  String?
  price        Float
  currency     String      @default("CNY")
  coverImage   String?     @map("cover_image")
  status       String      @default("active")
  stockVisible Boolean     @default(true) @map("stock_visible")
  sortOrder    Int         @default(0) @map("sort_order")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  inventory    Inventory[]
  orderItems   OrderItem[]

  @@map("products")
}

model Inventory {
  id                   Int        @id @default(autoincrement())
  productId            Int        @map("product_id")
  product              Product    @relation(fields: [productId], references: [id])
  cardContentEncrypted String     @map("card_content_encrypted")
  cardContentHash      String     @map("card_content_hash")
  cardSearchIndex      String?    @map("card_search_index")
  status               String     @default("available")
  orderItemId          Int?       @map("order_item_id")
  orderItem            OrderItem? @relation(fields: [orderItemId], references: [id])
  createdAt            DateTime   @default(now()) @map("created_at")
  soldAt               DateTime?  @map("sold_at")

  @@index([productId, status])
  @@index([cardContentHash])
  @@index([cardSearchIndex])
  @@map("inventory")
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int?        @map("user_id")
  user          User?       @relation(fields: [userId], references: [id])
  orderNo       String      @unique @map("order_no")
  email         String
  accessPin     String      @map("access_pin")
  totalAmount   Float       @map("total_amount")
  currency      String      @default("CNY")
  status        String      @default("pending")
  paymentMethod String?     @map("payment_method")
  paymentRef    String?     @map("payment_ref")
  expectedUsdt  Float?      @map("expected_usdt")
  tronWalletId  Int?        @map("tron_wallet_id")
  tronWallet    TronWallet? @relation(fields: [tronWalletId], references: [id])
  paidAt        DateTime?   @map("paid_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  items         OrderItem[]
  payments      Payment[]
  walletLedgers WalletLedger[]

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([tronWalletId, status])
  @@map("orders")
}

model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  passwordHash  String          @map("password_hash")
  balanceCents  Int             @default(0) @map("balance_cents")
  status        String          @default("active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  orders        Order[]
  walletLedgers WalletLedger[]
  topUps        WalletTopUp[]

  @@index([status, createdAt])
  @@map("users")
}

model TronWallet {
  id             Int           @id @default(autoincrement())
  address        String        @unique
  label          String?
  status         String        @default("active")
  priority       Int           @default(0)
  lastAssignedAt DateTime?     @map("last_assigned_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  orders         Order[]
  topUps         WalletTopUp[]

  @@index([status, priority, lastAssignedAt])
  @@map("tron_wallets")
}

model WalletTopUp {
  id             Int          @id @default(autoincrement())
  topUpNo        String       @unique @map("top_up_no")
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id])
  amountCents    Int          @map("amount_cents")
  expectedUsdt   Float?       @map("expected_usdt")
  paymentMethod  String       @map("payment_method")
  status         String       @default("pending")
  tronWalletId   Int?         @map("tron_wallet_id")
  tronWallet     TronWallet?  @relation(fields: [tronWalletId], references: [id])
  txHash         String?      @unique @map("tx_hash")
  tradeNo        String?      @unique @map("trade_no")
  callbackRaw    String?      @map("callback_raw")
  paidAt         DateTime?    @map("paid_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@index([tronWalletId, status])
  @@map("wallet_top_ups")
}

model WalletLedger {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  user              User      @relation(fields: [userId], references: [id])
  orderId           Int?      @map("order_id")
  order             Order?    @relation(fields: [orderId], references: [id])
  adminId           Int?      @map("admin_id")
  admin             Admin?    @relation(fields: [adminId], references: [id])
  amountCents       Int       @map("amount_cents")
  balanceBeforeCents Int      @map("balance_before_cents")
  balanceAfterCents Int       @map("balance_after_cents")
  type              String
  reference         String?   @unique
  note              String?
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([orderId])
  @@map("wallet_ledgers")
}

model OrderItem {
  id        Int        @id @default(autoincrement())
  orderId   Int        @map("order_id")
  order     Order      @relation(fields: [orderId], references: [id])
  productId Int        @map("product_id")
  product   Product    @relation(fields: [productId], references: [id])
  quantity  Int        @default(1)
  unitPrice Float      @map("unit_price")
  inventory Inventory[]

  @@map("order_items")
}

model Payment {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  order       Order    @relation(fields: [orderId], references: [id])
  method      String
  amount      Float
  currency    String   @default("CNY")
  txHash      String?  @unique @map("tx_hash")
  tradeNo     String?  @unique @map("trade_no")
  status      String   @default("pending")
  callbackRaw String?  @map("callback_raw")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([orderId, status])
  @@map("payments")
}

model Admin {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("admin")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  walletLedgers WalletLedger[]
  sensitiveActions AdminSensitiveAction[]

  @@map("admins")
}

model AdminSensitiveAction {
  id        Int       @id @default(autoincrement())
  adminId   Int       @map("admin_id")
  admin     Admin     @relation(fields: [adminId], references: [id])
  action    String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([adminId, action, expiresAt])
  @@map("admin_sensitive_actions")
}

model PaymentConfig {
  id         Int      @id @default(autoincrement())
  method     String   @unique
  configJson String   @map("config_json")
  status     String   @default("active")
  updatedAt  DateTime @updatedAt @map("updated_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("payment_configs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   Int?     @map("admin_id")
  action    String
  target    String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ip        String
  username  String
  success   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ip, createdAt])
  @@map("login_attempts")
}

model IpBlacklist {
  id           Int       @id @default(autoincrement())
  ip           String    @unique
  reason       String
  blockedUntil DateTime? @map("blocked_until")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("ip_blacklist")
}

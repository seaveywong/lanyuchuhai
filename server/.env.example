APP_NAME="BlueReach"
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_ALLOWED_IPS=
TRUST_PROXY=1
BODY_LIMIT=1mb

JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=keygo-api
JWT_AUDIENCE=keygo-admin

CARD_ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789

TRONGRID_API_KEY=your-trongrid-api-key
USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
MERCHANT_WALLET_ADDRESS=YOUR_TRC20_WALLET_ADDRESS
MERCHANT_PRIVATE_KEY=
